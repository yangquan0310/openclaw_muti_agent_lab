{
  "version": "1.0.0",
  "last_updated": "2026-04-13T15:28:00+08:00",
  "description": "实验室和教研室仓库日志系统维护配置",
  "log_repositories": [
    {
      "name": "实验室仓库日志",
      "path": "/root/实验室仓库/日志文件/",
      "owner": "大管家",
      "auto_sync": true,
      "sync_targets": ["GitHub", "备份服务器"],
      "retention_days": 180,
      "permanent_log_types": ["系统维护", "项目里程碑"],
      "index_generation": true
    },
    {
      "name": "教研室仓库日志",
      "path": "/root/教研室仓库/日志文件/",
      "owner": "大管家",
      "auto_sync": true,
      "sync_targets": ["私有加密备份服务器"],
      "retention_days": 3650,
      "permanent_log_types": ["教务管理", "教研室管理"],
      "index_generation": true,
      "encryption_required": true
    }
  ],
  "maintenance_tasks": [
    {
      "name": "日志完整性校验",
      "schedule": "每日03:00",
      "script": "lab-backup-manager/scripts/log_verify.sh",
      "action": "对所有日志文件进行SHA256校验，生成校验报告"
    },
    {
      "name": "日志索引生成",
      "schedule": "每日03:30",
      "script": "lab-backup-manager/scripts/index_generator.py",
      "action": "生成当日日志的多维度索引文件，支持快速检索"
    },
    {
      "name": "过期日志归档",
      "schedule": "每月1日02:00",
      "script": "lab-backup-manager/scripts/log_archive.py",
      "action": "归档超过保留期限的日志，生成压缩包存储到备份系统"
    },
    {
      "name": "日志备份同步",
      "schedule": "每6小时",
      "script": "lab-backup-manager/scripts/log_sync.sh",
      "action": "同步日志文件到所有配置的备份目标"
    }
  ],
  "log_standard": {
    "file_naming": "YYYY-MM-DD/HH-MM-SS-[来源]-[类型].md",
    "required_fields": ["时间", "操作人", "操作类型", "详细内容", "结果确认"],
    "format": "Markdown",
    "max_file_size_mb": 10
  }
}
