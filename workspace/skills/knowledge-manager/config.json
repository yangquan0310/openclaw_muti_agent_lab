{
  "llm": {
    "default_provider": "tencent",
    "providers": {
      "ark": {
        "name": "火山引擎方舟",
        "base_url": "https://ark.cn-beijing.volces.com/api/v3",
        "default_model": "deepseek-v3-2-251201",
        "api_key_env": "ARK_API_KEY",
        "timeout": 30,
        "temperature": 0.3,
        "max_tokens": 2000
      },
      "tencent_token": {
        "name": "腾讯云tokenhub",
        "base_url": "https://tokenhub.tencentmaas.com/v1",
        "default_model": "deepseek-v3.2",
        "api_key_env": "TOKENHUB_API_KEY",
        "timeout": 30,
        "temperature": 0.3,
        "max_tokens": 2000
      },
      "tencent_token_plan": {
        "name": "腾讯云tokenhub_plan",
        "base_url": "https://api.lkeap.cloud.tencent.com/plan/v3",
        "default_model": "deepseek-v3.2",
        "api_key_env": "TOKENHUB_PLAN_API_KEY",
        "timeout": 30,
        "temperature": 0.3,
        "max_tokens": 2000
      }
      
    }
  },
  "semantic_scholar": {
    "api_key_env": "SEMANTIC_SCHOLAR_API_KEY",
    "request_interval": 0.5,
    "default_limit": 20
  },
  "storage": {
    "root_path": "/root/实验室仓库/项目文件/",
    "knowledge_base_dir": "知识库/",
    "notes_dir": "知识库/笔记/",
    "index_file": "index.json",
    "notes_file_format": "{主题}.json"
  },
  "log": {
    "log_root": "/root/实验室仓库/日志文件/",
    "log_file_format": "%Y-%m-%d/%H-%M-%S-心理学家-{任务类型}.md",
    "auto_logging": true
  }
}