        "source": "file",
        "path": "~/.openclaw/credentials/lark.secrets.json"
      }
    }
  },
  "mcp": {
    "servers": {
      "tencent-docs": {
        "url": "https://docs.qq.com/openapi/mcp",
        "headers": {
          "Authorization": "03e03d2067a24d7bba38840eb1c20853"
        }
      },
      "tencent-docengine": {
        "url": "https://docs.qq.com/api/v6/doc/mcp",
        "headers": {
          "Authorization": "03e03d2067a24d7bba38840eb1c20853"
        }
      },
      "tencent-sheetengine": {
        "url": "https://docs.qq.com/api/v6/sheet/mcp",
        "headers": {
          "Authorization": "03e03d2067a24d7bba38840eb1c20853"
        }
      },
      "manage-project": {
        "command": "python3",
        "args": [
          "/root/.openclaw/workspace/skills/manage-project/mcp/server.py"
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      },
      "feishu": {
        "enabled": false
      },
      "openclaw-lark": {
        "enabled": true
      },
      "memory-wiki": {
        "enabled": true
      },
      "adp-openclaw": {
        "enabled": false
      },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "memory-lancedb": {
        "enabled": false,
        "config": {
          "embedding": {
            "apiKey": "${KIMICODE_API_KEY}",
            "baseUrl": "https://api.moonshot.cn/v1",
            "model": "moonshot-v1-8k",
            "dimensions": 1536
          },
          "autoCapture": true,
          "autoRecall": true
        }
      },
      "ddingtalk": {
        "enabled": false
      },
      "wecom": {
        "enabled": false
      },
      "openclaw-plugin-yuanbao": {
        "enabled": false
      },
      "openclaw-weixin": {
        "enabled": true
      },
      "lightclawbot": {
        "enabled": true
      },
      "memory-tencentdb": {
        "enabled": false
      },
      "qqbot": {
        "enabled": true
      },
      "agent-self-development": {
        "enabled": true,
        "config": {
          "metacognition": {
            "enabled": true,
            "planning": true,
            "monitoring": true
          },
          "workingMemory": {
            "enabled": true,
            "trackSubagents": true,
            "autoArchive": true
          },
          "personality": {
            "enabled": true
          },
          "archive": {
            "maxArchivedTasks": 50
          }
        },
        "hooks": {
          "allowPromptInjection": true,
          "allowConversationAccess": true
        }
      },
      "deepseek": {
        "enabled": true
      },
      "moonshot": {
        "enabled": true
      }
    },
    "allow": [
      "adp-openclaw",
      "browser",
      "ddingtalk",
      "lightclawbot",
      "memory-core",
      "memory-lancedb",
      "memory-wiki",
      "openclaw-lark",
      "openclaw-plugin-yuanbao",
      "openclaw-weixin",
      "qqbot",
      "wecom",
      "agent-self-development",
      "deepseek",
      "moonshot"
    ],
    "load": {
      "paths": []
    },
    "slots": {
      "memory": "memory-core"
    }
  }
}
