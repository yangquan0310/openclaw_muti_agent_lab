{
  "id": "agent-self-development",
  "name": "Agent Self-Development",
  "version": "1.2.4",
  "description": "OpenClaw plugin for agent self-development based on Piaget's cognitive development theory",
  "main": "src/index.js",
  "type": "native",
  "extensions": ["./src/index.js"],
  "minVersion": "2026.4.0",
  "skills": ["skills"],
  "configSchema": {
    "type": "object",
    "properties": {
      "metacognition": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "planning": { "type": "boolean", "default": true },
          "monitoring": { "type": "boolean", "default": true },
          "regulation": { "type": "boolean", "default": true }
        }
      },
      "workingMemory": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "trackSubagents": { "type": "boolean", "default": true },
          "autoArchive": { "type": "boolean", "default": true }
        }
      },
      "assimilation": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "dailyCron": { "type": "string", "default": "0 0 * * *" },
          "autoUpdate": { "type": "boolean", "default": false },
          "updateThreshold": { "type": "number", "default": 0.8 }
        }
      },
      "llm": {
        "type": "object",
        "properties": {
          "model": { "type": "string", "default": "kimi-for-coding" },
          "provider": { "type": "string", "default": "kimicode" }
        }
      }
    }
  }
}
