# 默认排除所有文件
/*

# 排除敏感文件
.env
*.key
*.secret
*.pem
*.env*
credentials.json
tokens.json

# 排除备份文件
*.bak
*.backup
*.old
*.tmp
*.tmp.md
*.backup.*
*.bak.*

# 排除临时文件夹
*/temp/
*/tmp/
temp/
tmp/

# 排除测试文件
*test_*.json
*test_*.md

# 排除日志和缓存文件
*.log
*.cache
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# 排除OpenClaw内部文件
.openclaw
node_modules/
.cache/
*.db
sessions/
devices/
openclaw-*/
subagents/
exec-approvals.json
identity/
venv/
*/venv/
*/sessions/
*.db-journal
*.pyc
__pycache__/
.pytest_cache/
**/.openclaw/
**/*.state.json

# 排除IDE配置文件
.vscode/
.idea/


# 允许需要备份的文件
!/README.md
!/requirements.txt
!/.gitignore
!/openclaw.json
!/workspace/
!/cron/
!/cron/jobs.json

# 排除 cron 运行记录
/cron/runs/
/worspace/skills/.skills_store_lock.json